# ========================================
# Code4U - Configuration Apache pour IONOS
# ========================================

# Activer le moteur de réécriture
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Redirection HTTPS (si SSL activé)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
    
    # Réécriture des URLs sans extension vers .html
    # Exemple: /web -> /web.html, /logiciel -> /logiciel.html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/admin
    RewriteCond %{REQUEST_URI} !^/assets
    RewriteCond %{REQUEST_URI} !^/logs
    RewriteCond %{REQUEST_URI} !\.(html|php|css|js|png|jpg|jpeg|gif|svg|webp|ico|pdf)$ [NC]
    RewriteRule ^([^/]+)/?$ $1.html [L]
    
    # Protection des fichiers sensibles
    <FilesMatch "\.(htaccess|htpasswd|ini|log|sql|md)$">
        Order Allow,Deny
        Deny from all
    </FilesMatch>
    
    # Protection du dossier admin (optionnel - décommentez si besoin)
    # <DirectoryMatch "^/code4u/admin">
    #     AuthType Basic
    #     AuthName "Admin Area"
    #     AuthUserFile /path/to/.htpasswd
    #     Require valid-user
    # </DirectoryMatch>
</IfModule>

# ========================================
# Configuration PHP
# ========================================
<IfModule mod_php7.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    php_value max_execution_time 300
    php_value max_input_time 300
    php_value memory_limit 256M
    php_flag display_errors Off
    php_flag log_errors On
    php_value error_log logs/php_errors.log
</IfModule>

# ========================================
# Sécurité
# ========================================
# Désactiver l'affichage de la liste des répertoires
Options -Indexes

# Protection contre les injections de fichiers
<FilesMatch "\.(php|phtml|php3|php4|php5|pl|py|jsp|asp|sh|cgi)$">
    <IfModule mod_headers.c>
        Header set X-Content-Type-Options "nosniff"
        Header set X-Frame-Options "SAMEORIGIN"
        Header set X-XSS-Protection "1; mode=block"
    </IfModule>
</FilesMatch>

# ========================================
# Compression GZIP
# ========================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# ========================================
# Cache des fichiers statiques
# ========================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ========================================
# Pages d'erreur personnalisées (optionnel)
# ========================================
# ErrorDocument 404 /code4u/404.html
# ErrorDocument 500 /code4u/500.html
